{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client --clear",
    "ios": "expo run:ios --device 'iPhone 17 Pro Max'",
    "ios:start": "xcrun simctl boot 'iPhone 17 Pro Max' 2>/dev/null; open -a Simulator; expo start --dev-client",
    "android": "expo run:android",
    "android:start": "expo start --dev-client --android",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "web": "expo start --web",
    "eas:preview:ios": "eas build --profile preview --platform ios",
    "eas:preview:android": "eas build --profile preview --platform android",
    "eas:dev:ios": "eas build --profile development --platform ios"
  },
  "dependencies": {
    "@av/forms": "1.0.0",
    "@av/store": "1.0.0",
    "@av/ui": "1.0.0",
    "@aws-amplify/react-native": "^1.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "6",
    "@react-navigation/native": "6",
    "@react-navigation/native-stack": "6",
    "expo": "~54.0.24",
    "expo-dev-client": "^6.0.18",
    "expo-status-bar": "~3.0.8",
    "native-base": "3.4.28",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.4.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
