{
  "name": "avcallbutton",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
  "apps/*",
  "packages/ui",
  "packages/eslint-config",
  "packages/typescript-config"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "turbo": "^2.6.0",
    "typescript": "^5.2.2"
  }
}
