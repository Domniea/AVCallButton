generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  type      String
  createdAt DateTime @default(now())

  memberships    Membership[]
  shows          Show[]
  invites        Invite[]
  workspaceRoles WorkspaceRole[]
}

model WorkspaceRole {
  uuid        String    @id @default(uuid())
  workspaceId String
  rank        Int
  name        String
  description String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invites Invite[]
  memberships Membership[]

  @@unique([workspaceId, rank])
}

model Membership {
  id String @id @default(uuid())

  userId      String
  workspaceId String
  email       String?

  workspaceRoleId String
  status          String   @default("active")
  joinedAt        DateTime @default(now())

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  workspaceRole WorkspaceRole @relation(fields: [workspaceRoleId], references: [uuid], onDelete: Restrict)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@index([workspaceRoleId])
}

model Invite {
  id          String    @id @default(uuid())
  email       String
  workspaceRoleId String
  workspaceRole   WorkspaceRole @relation(fields: [workspaceRoleId], references: [uuid], onDelete: Restrict)
  status      String    @default("pending")
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   String
  createdAt   DateTime  @default(now())

  @@unique([email, workspaceId])
  @@index([token])
  @@index([workspaceId])
  @@index([email])
}

model Show {
  id        String    @id @default(uuid())
  name      String
  status    String
  location  String?
  startTime DateTime?
  endTime   DateTime?
  createdAt DateTime  @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  logs     Log[]
  messages Message[]

  @@index([workspaceId])
  @@index([status])
  @@index([startTime])
}

model Log {
  id        String   @id @default(uuid())
  message   String
  createdAt DateTime @default(now())

  showId String
  show   Show   @relation(fields: [showId], references: [id])

  @@index([showId])
  @@index([createdAt])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  showId String
  userId String

  show Show @relation(fields: [showId], references: [id])

  @@index([showId])
  @@index([createdAt])
}
