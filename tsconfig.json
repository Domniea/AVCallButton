{
  "$schema": "https://json.schemastore.org/tsconfig",
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./apps/mobile"
    },
    {
      "path": "./apps/web"
    },
    {
      "path": "./packages/ui"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "baseUrl": ".",
