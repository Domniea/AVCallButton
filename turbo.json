{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",

  "globalEnv": [
    "APP_ENV"
  ],

  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        "dist/**",
        ".expo/**",
        "android/**",
        "ios/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
